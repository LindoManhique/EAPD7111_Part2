@model TechMoves.Models.Contract

@{
    ViewData["Title"] = "Contract Details";
}

<div class="container mt-4">

    <div class="card shadow p-4">

        <h2>Contract Details</h2>
        <hr />

        <dl class="row">

            <dt class="col-sm-3">Client</dt>
            <dd class="col-sm-9">@Model.Client?.Name</dd>

            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.StartDate</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.EndDate</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Service Level</dt>
            <dd class="col-sm-9">@Model.ServiceLevel</dd>

        </dl>

        <hr />

        <h5>Agreement File</h5>

        @if (!string.IsNullOrEmpty(Model.AgreementFilePath))
        {
            <a class="btn btn-success"
               href="@Model.AgreementFilePath"
               target="_blank">
                Open PDF
            </a>
        }
        else
        {
            <p class="text-muted">No agreement uploaded</p>
        }

        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>

    </div>

</div>