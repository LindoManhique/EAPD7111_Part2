@model TechMoves.Models.Contract

@{
    ViewData["Title"] = "Create Contract";
}

<div class="container mt-4">

    <div class="card shadow p-4">

        <h2 class="mb-2">Create New Contract</h2>
        <p class="text-muted">Add a new client contract with SLA and signed agreement upload.</p>

        <form asp-action="Create" enctype="multipart/form-data">

            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label class="form-label">Client</label>
                <select asp-for="ClientId" class="form-control" asp-items="ViewBag.ClientId">
                    <option value="">-- Select Client --</option>
                </select>
            </div>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label>Start Date</label>
                    <input asp-for="StartDate" class="form-control" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>End Date</label>
                    <input asp-for="EndDate" class="form-control" />
                </div>

            </div>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label>Status</label>
                    <select asp-for="Status" class="form-control">
                        <option>Draft</option>
                        <option>Active</option>
                        <option>Expired</option>
                        <option>On Hold</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Service Level</label>
                    <input asp-for="ServiceLevel" class="form-control" />
                </div>

            </div>

            <div class="mb-3">
                <label>Signed Agreement (PDF only)</label>
                <input type="file" name="file" class="form-control" />
                <span class="text-danger">@Html.ValidationMessage("file")</span>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary">Create Contract</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>

        </form>

    </div>
</div>