@model TechMoves.Models.Contract

@{
    ViewData["Title"] = "Edit Contract";
}

<div class="container mt-4">

    <div class="card shadow p-4">

        <h2>Edit Contract</h2>
        <p class="text-muted">Update contract details or replace signed agreement.</p>

        <form asp-action="Edit" enctype="multipart/form-data">

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label>Client</label>
                <select asp-for="ClientId" class="form-control" asp-items="ViewBag.ClientId"></select>
            </div>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label>Start Date</label>
                    <input asp-for="StartDate" class="form-control" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>End Date</label>
                    <input asp-for="EndDate" class="form-control" />
                </div>

            </div>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label>Status</label>
                    <select asp-for="Status" class="form-control">
                        <option>Draft</option>
                        <option>Active</option>
                        <option>Expired</option>
                        <option>On Hold</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Service Level</label>
                    <select asp-for="ServiceLevel" class="form-control">
                        <option value="">-- Select Level --</option>
                        <option>Gold</option>
                        <option>Silver</option>
                        <option>Bronze</option>
                    </select>
                </div>

            </div>

            <div class="mb-3">
                <label>Current Agreement</label><br />

                @if (!string.IsNullOrEmpty(Model.AgreementFilePath))
                {
                    <a class="btn btn-sm btn-success" href="@Model.AgreementFilePath" target="_blank">
                        View Current PDF
                    </a>
                }
                else
                {
                    <span class="text-muted">No file uploaded</span>
                }
            </div>

            <div class="mb-3">
                <label>Replace Agreement (PDF only)</label>
                <input type="file" name="file" class="form-control" />
                <span class="text-danger">@Html.ValidationMessage("file")</span>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            </div>

        </form>

    </div>

</div>