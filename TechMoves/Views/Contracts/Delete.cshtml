@model TechMoves.Models.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<div class="container mt-4">

    <div class="card shadow p-4 border-danger">

        <h2 class="text-danger">Delete Contract</h2>

        <p class="text-warning">
            ⚠ Are you sure you want to delete this contract? This action cannot be undone.
        </p>

        <dl class="row">

            <dt class="col-sm-3">Client</dt>
            <dd class="col-sm-9">@Model.Client?.Name</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Service Level</dt>
            <dd class="col-sm-9">@Model.ServiceLevel</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger">
                Delete Contract
            </button>

            <a asp-action="Index" class="btn btn-secondary">Cancel</a>

        </form>

    </div>

</div>