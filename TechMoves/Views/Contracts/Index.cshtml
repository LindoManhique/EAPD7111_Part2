@model IEnumerable<TechMoves.Models.Contract>

@{
    ViewData["Title"] = "Contracts";
}

<h1>Contracts</h1>

<!-- 🔥 FILTER FORM (LINQ UI) -->
<form method="get" asp-action="Index">
    <div class="row mb-3">

        <div class="col-md-3">
            <input type="text"
                   name="status"
                   class="form-control"
                   placeholder="Status (Active / Expired / On Hold)" />
        </div>

        <div class="col-md-3">
            <input type="date"
                   name="startDate"
                   class="form-control" />
        </div>

        <div class="col-md-3">
            <input type="date"
                   name="endDate"
                   class="form-control" />
        </div>

        <div class="col-md-3">
            <button type="submit" class="btn btn-primary">Filter</button>
            <a asp-action="Index" class="btn btn-secondary">Reset</a>
        </div>

    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Client</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Service Level</th>
            <th>Agreement</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Client?.Name</td>
                <td>@item.StartDate</td>
                <td>@item.EndDate</td>
                <td>@item.Status</td>
                <td>@item.ServiceLevel</td>

                <td>
                    @if (!string.IsNullOrEmpty(item.AgreementFilePath))
                    {
                        <a asp-action="Download"
                           asp-route-fileName="@item.AgreementFilePath.Split('/').Last()"
                           class="btn btn-success btn-sm">
                            Download PDF
                        </a>
                    }
                    else
                    {
                        <span>No file</span>
                    }
                </td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>