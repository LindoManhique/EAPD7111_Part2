@model TechMoves.Models.Client

@{
    ViewData["Title"] = "Create Client";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Create Client</h2>
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ContactDetails" class="form-label"></label>
                <input asp-for="ContactDetails" class="form-control" />
                <span asp-validation-for="ContactDetails" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Region" class="form-label"></label>
                <input asp-for="Region" class="form-control" />
                <span asp-validation-for="Region" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Create Client</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}