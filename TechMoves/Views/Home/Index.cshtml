@{
    ViewData["Title"] = "GLMS Dashboard";
}

<style>
    .hero {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: white;
        padding: 50px 30px;
        border-radius: 12px;
        margin-bottom: 30px;
    }

    .hero h1 {
        font-size: 2.5rem;
        font-weight: 700;
    }

    .hero p {
        font-size: 1.1rem;
        opacity: 0.9;
        max-width: 900px;
    }

    .card {
        border: none;
        border-radius: 12px;
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-5px);
    }

    .card-title {
        font-weight: 600;
    }

    .btn-primary {
        border-radius: 8px;
        padding: 8px 18px;
    }

    .section-title {
        font-weight: 600;
        margin-bottom: 20px;
    }
</style>

<div class="hero">
    <h1>Global Logistics Management System (GLMS)</h1>

    <p>
        Welcome to <strong>TechMove Logistics</strong> enterprise platform.
        This system centralises contract management, service request processing,
        and financial tracking for global freight operations.
    </p>

    <p>
        Designed to eliminate fragmented spreadsheets and manual workflows,
        GLMS ensures <strong>accuracy, compliance, and real-time operational control</strong>
        across all client logistics activities.
    </p>
</div>

<h3 class="section-title">System Modules</h3>

<div class="row">

    <div class="col-md-4 mb-3">
        <div class="card shadow-sm p-3">
            <h5 class="card-title">Client Management</h5>
            <p>Maintain global client records including contact details and regions.</p>
            <a class="btn btn-primary" asp-controller="Clients" asp-action="Index">
                Open Module
            </a>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow-sm p-3">
            <h5 class="card-title">Contract Management Hub</h5>
            <p>
                Store legal agreements, SLA details, and track contract lifecycle
                (Draft, Active, Expired, On Hold).
            </p>
            <a class="btn btn-primary" asp-controller="Contracts" asp-action="Index">
                Open Module
            </a>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow-sm p-3">
            <h5 class="card-title">Service Request Processing</h5>
            <p>
                Log and manage service requests linked to active contracts with automated validation.
            </p>
            <a class="btn btn-primary" asp-controller="ServiceRequests" asp-action="Index">
                Open Module
            </a>
        </div>
    </div>

</div>

<hr />

<div class="text-center mt-4">
    <p class="text-muted">
        Enterprise Prototype • ASP.NET Core MVC • Entity Framework Core • Async API Integration
    </p>
</div>