@model TechMoves.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<div class="container mt-4">

    <div class="card shadow p-4 border-danger">

        <h2 class="text-danger">Delete Service Request</h2>

        <p>Are you sure you want to delete this record?</p>

        <hr />

        <dl class="row">

            <dt class="col-sm-3">Contract</dt>
            <dd class="col-sm-9">@Model.ContractId</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Cost</dt>
            <dd class="col-sm-9">@Model.Cost</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

        </dl>

        <form asp-action="Delete" method="post">

            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger">
                Delete
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>

</div>