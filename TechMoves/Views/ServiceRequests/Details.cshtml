@model TechMoves.Models.ServiceRequest

@{
    ViewData["Title"] = "Service Request Details";
}

<div class="container mt-4">

    <div class="card shadow p-4">

        <h2>Service Request Details</h2>

        <hr />

        <dl class="row">

            <dt class="col-sm-3">Contract</dt>
            <dd class="col-sm-9">@Model.ContractId</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Cost (USD)</dt>
            <dd class="col-sm-9">@Model.Cost</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

        </dl>

        <div class="mt-3 d-flex gap-2">

            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-primary">
                Edit
            </a>

            <a asp-action="Delete"
               asp-route-id="@Model.Id"
               class="btn btn-danger">
                Delete
            </a>

            <a asp-action="Index"
               class="btn btn-secondary">
                Back
            </a>

        </div>

    </div>
</div>