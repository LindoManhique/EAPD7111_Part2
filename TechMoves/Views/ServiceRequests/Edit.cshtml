@model TechMoves.Models.ServiceRequest

@{
    ViewData["Title"] = "Edit Service Request";
}

<div class="container mt-4">

    <div class="card shadow p-4">

        <h2>Edit Service Request</h2>
        <p class="text-muted">Update request details or status.</p>

        <form asp-action="Edit">

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label>Contract</label>
                <select asp-for="ContractId" class="form-control" asp-items="ViewBag.ContractId"></select>
            </div>

            <div class="mb-3">
                <label>Description</label>
                <input asp-for="Description" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Cost (USD)</label>
                <input asp-for="Cost" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Status</label>
                <input asp-for="Status" class="form-control" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            </div>

        </form>

    </div>
</div>