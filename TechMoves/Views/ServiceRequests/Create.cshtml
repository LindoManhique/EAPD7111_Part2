@model TechMoves.Models.ServiceRequest

@{
    ViewData["Title"] = "Create Service Request";
}

<div class="container mt-4">

    <div class="card shadow p-4">

        <h2>Create Service Request</h2>
        <p class="text-muted">
            Log a new logistics service request linked to an active contract.
        </p>

        <form asp-action="Create">

            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label class="form-label">Contract</label>
                <select asp-for="ContractId" class="form-control" asp-items="ViewBag.ContractId">
                    <option value="">-- Select Contract --</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <input asp-for="Description" class="form-control" placeholder="Describe the service request..." />
            </div>

            <div class="mb-3">
                <label class="form-label">Cost (USD)</label>
                <input asp-for="Cost" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Status</label>
                <select asp-for="Status" class="form-control">
                    <option>Pending</option>
                    <option>In Progress</option>
                    <option>Completed</option>
                </select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create Request</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>

        </form>

    </div>
</div>